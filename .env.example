# Expo / EAS environment (copy to .env — never commit .env)

# Supabase (optional — defaults in constants/config.js)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps — restrict to com.trotro.os + release SHA-1 in Cloud Console
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=

# Play Store — required before submission
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.com/privacy

# Production crash monitoring (optional but recommended)
EXPO_PUBLIC_SENTRY_DSN=

# Optional backend — see server/api/README.md
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_KEY=
EXPO_PUBLIC_ETA_SERVICE_URL=
