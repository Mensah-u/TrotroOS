{
  "expo": {
    "name": "TrotroOS",
    "slug": "TrotroOSv2",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trotrops",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trotro.os"
    },
    "android": {
      "package": "com.trotro.os",
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#0C0C0C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB2ikuzHxXpKO3KeTXsLYP6yiZUyUauf0s"
        }
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0C0C0C",
          "dark": {
            "backgroundColor": "#0C0C0C"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "TrotroOS uses your location only while the app is open, so mates can see where to pick you up and you can see nearby vehicles in real time.",
          "isAndroidBackgroundLocationEnabled": false,
          "isIosBackgroundLocationEnabled": false
        }
      ]
    ],
    "experiments": {},
    "extra": {
      "eas": {
        "projectId": "e5b35d55-67bc-4136-b257-1d9886669ad8"
      },
      "privacyPolicyNote": "Set EXPO_PUBLIC_PRIVACY_POLICY_URL in EAS for Play Console"
    },
    "owner": "mensah-u"
  }
}
